# Anthropic API Key — 필수 (없으면 LLM 호출 실패 후 fallback 사용됨)
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# 사용할 모델 (선택, 기본값: claude-sonnet-4-6)
# 옵션:
#   - claude-opus-4-7      : 가장 똑똑함, 느림, 비용 ↑
#   - claude-sonnet-4-6    : 균형 (기본 권장)
#   - claude-haiku-4-5-20251001 : 빠름, 저렴, 추론 약함
ANTHROPIC_MODEL=claude-sonnet-4-6
