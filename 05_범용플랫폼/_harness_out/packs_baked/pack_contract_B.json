    "decisionTables": [
      {
        "id": "dt_route",
        "description": "최종 분기 판정(자동승인/법무검토HITL/반려). riskAppetite=중도(속도 우선·핵심위험만)·2단계 단순결재 반영. when은 슬롯·1차판정 참조, 위에서 아래로 첫 매칭 적용.",
        "rules": [
          {
            "when": "sanctionCheckResult == '미확인' OR sanctionCheckResult == '해당'",
            "then": "법무검토(HITL) — 제재 데이터 갭으로 수기 확인 필수 보강(해당 시 반려 검토)"
          },
          {
            "when": "requiredClausesPresent 에 필수조항 누락 존재",
            "then": "반려 — 필수조항 보완 후 재접수"
          },
          {
            "when": "extractConfidence < 0.7 OR 비표준 조항 해석 불가",
            "then": "법무검토(HITL) — 비정형 조항 해석 이관"
          },
          {
            "when": "toxicClauseFlags 에 위험=high 핵심플래그 존재",
            "then": "법무검토(HITL) — 독소조항 실질위험 전문판단"
          },
          {
            "when": "templateDeviationItems 에 편차=중대 존재",
            "then": "법무검토(HITL) — 편차 수용 가능성 판단"
          },
          {
            "when": "contractAmount >= 30000000",
            "then": "법무검토(HITL) → 대표 결재 — 고액 건 핵심위험 점검"
          },
          {
            "when": "riskGrade == 'low' AND contractAmount < 5000000 AND 필수조항 완비 AND 핵심플래그 없음 AND sanctionCheckResult=='해당없음'",
            "then": "자동승인 — 담당 확인 종결(대표 결재 생략 가능)"
          },
          {
            "when": "그 외(회색지대 포함)",
            "then": "법무검토(HITL) 생략 가능 시 담당 → 대표 결재(중도 성향: 회색지대는 대표 결재로 흡수, 핵심위험만 법무 회부)"
          }
        ]
      },
      {
        "id": "dt_legal_review_outcome",
        "description": "법무검토(HITL) 결과 처리 분기(전문가 입력 후 후속 결정론 처리)",
        "rules": [
          {
            "when": "legalReviewResult == '수용'",
            "then": "대표 결재 단계로 진행"
          },
          {
            "when": "legalReviewResult == '수정요청'",
            "then": "담당자에게 수정 요청·사유 기록 후 재검토 루프"
          },
          {
            "when": "legalReviewResult == '반려'",
            "then": "반려 처리·사유 Notion 기록·요청자 통지"
          }
        ]
      },
      {
        "id": "dt_renewal_notice",
        "description": "만기·자동갱신 통지 알림 예약 분기",
        "rules": [
          {
            "when": "autoRenewalClause 존재 AND 당사 거절의사 없음",
            "then": "자동갱신 통지기한(만기 - noticePeriodDays)에 갱신 검토 알림 예약"
          },
          {
            "when": "autoRenewalClause 존재 AND noticePeriodDays 미기재",
            "then": "기본 통지기한 30일 적용·알림 예약 + 통지기한 미정 플래그"
          },
          {
            "when": "autoRenewalClause 없음",
            "then": "만기 60일 전 재계약 검토 알림 예약"
          }
        ]
      }
    ],
    "thresholds": [
      {
        "id": "th_renewal_notice_default",
        "expr": "noticeAlertDate = contractTermEnd - max(noticePeriodDays, 30)일",
        "flag": "갱신통지_알림예약"
      },
      {
        "id": "th_amount_legal_review",
        "expr": "contractAmount >= 30000000",
        "flag": "고액_법무검토_의무"
      },
      {
        "id": "th_amount_auto_approve",
        "expr": "contractAmount < 5000000 AND riskGrade == 'low'",
        "flag": "자동승인_후보"
      },
      {
        "id": "th_amount_exec_approval",
        "expr": "contractAmount >= 5000000",
        "flag": "대표결재_필요"
      },
      {
        "id": "th_liability_cap",
