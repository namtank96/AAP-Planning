{
  "id": "contract_B",
  "label": "계약 관리",
  "flow": [
    {
      "id": "sp1",
      "label": "계약 건 접수·인입",
      "kind": "input",
      "loopPhase": "Data",
      "explain": "Notion 계약DB의 신규 행 또는 Google Drive 업로드를 트리거로 신규체결/갱신/변경 건을 인입하고 요청자·거래처·유형을 식별한다(월 15건, 수기·SaaS 혼재)."
    },
    {
      "id": "sp2",
      "label": "계약서 파싱·핵심정보 추출",
      "kind": "auto",
      "loopPhase": "Data",
      "explain": "Google Drive 계약서(PDF/문서)에서 계약 유형·금액·기간·갱신조건·주요 조항을 추출해 Notion 구조화 필드로 정규화한다."
    },
    {
      "id": "sp3",
      "label": "필수조항·표준템플릿 편차 점검",
      "kind": "auto",
      "loopPhase": "Reasoning",
      "explain": "계약 유형별 필수조항(목적·대금·기간·해지·비밀유지 등) 누락 여부와 B사 표준템플릿 대비 문구 편차를 룰 기반으로 대조한다."
    },
    {
      "id": "sp4",
      "label": "독소(위험)조항 점검",
      "kind": "auto",
      "loopPhase": "Reasoning",
      "explain": "무제한 손해배상·일방적 자동갱신·과도한 위약벌·관할/준거법 불리 등 위험조항을 탐지하되, 중도 성향상 핵심 위험만 플래그한다."
    },
    {
      "id": "sp5",
      "label": "거래처 제재·리스크 점검",
      "kind": "auto",
      "loopPhase": "Reasoning",
      "explain": "거래처를 제재/거래제한 리스트와 대조하나, 외부 신용·제재 데이터 소스가 없어 수기 확인 보강 단계로 처리한다(데이터 갭)."
    },
    {
      "id": "sp6",
      "label": "인지세·만기/자동갱신 통지기한 산정",
      "kind": "auto",
      "loopPhase": "Reasoning",
      "explain": "계약 금액·유형으로 인지세 과세 여부·세액을 산정하고, 만기일·자동갱신 통지기한(예: 만기 N일 전)을 계산해 알림 일정을 예약한다."
    },
    {
      "id": "sp7",
      "label": "금액별 결재선 결정·분기 판정",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "금액 구간·위험 등급을 종합해 자동승인/법무검토(HITL)/반려로 분기하고, 2단계 단순결재(담당→대표) 결재선을 구성한다.",
      "gate": {
        "label": "금액별 결재선 결정·분기 판정",
        "decisions": [
          {
            "key": "review0",
            "label": "법무검토",
            "toast": "법무검토 처리"
          },
          {
            "key": "reject",
            "label": "반려",
            "toast": "반려 처리"
          },
          {
            "key": "auto",
            "label": "자동승인",
            "toast": "자동승인 처리"
          }
        ]
      }
    },
    {
      "id": "sp8",
      "label": "법무검토(HITL) 처리",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "플래그된 위험조항·편차·제재 의심 건을 법무 검토자에게 이관해 수용/수정요청/반려를 받고 사유를 기록한다.",
      "gate": {
        "label": "법무검토(HITL) 처리",
        "decisions": [
          {
            "key": "ok",
            "label": "확인·진행",
            "toast": "확인했습니다"
          },
          {
            "key": "revise",
            "label": "보완 요청",
            "toast": "보완을 요청합니다"
          }
        ]
      }
    },
    {
      "id": "sp9",
      "label": "결재·전자서명 체결",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "대표 결재 승인 후 DocuSign으로 전자서명을 발송·완료해 체결을 확정한다.",
      "gate": {
        "label": "결재·전자서명 체결",
        "decisions": [
          {
            "key": "review0",
            "label": "법무검토",
            "toast": "법무검토 처리"
          },
          {
            "key": "reject",
            "label": "반려",
            "toast": "반려 처리"
          },
          {
            "key": "auto",
            "label": "자동승인",
            "toast": "자동승인 처리"
          }
        ]
      }
    },
    {
      "id": "sp10",
      "label": "계약관리대장 등록·후속 알림 설정",
      "kind": "auto",
      "loopPhase": "Learning",
      "explain": "체결 완료 건을 Notion 계약관리대장에 등록하고 서명본을 Google Drive에 보관하며 만기·갱신 통지 알림을 활성화한다."
    }
  ],
