  "knowledge": {
    "lookupTables": [
      {
        "id": "lt_required_clauses",
        "description": "계약 유형별 필수조항 체크리스트(누락 여부 결정론 대조용)",
        "entries": [
          {
            "match": "유형=용역/도급",
            "result": "필수: 계약목적·대금및지급조건·계약기간·해지(중도해지)·비밀유지·손해배상·분쟁해결(관할)"
          },
          {
            "match": "유형=라이선스/SaaS구독",
            "result": "필수: 이용범위·라이선스료·기간·자동갱신조건·SLA·데이터처리(개인정보)·해지·비밀유지"
          },
          {
            "match": "유형=업무위탁/위임",
            "result": "필수: 위탁업무범위·보수·기간·재위탁제한·비밀유지·손해배상·해지"
          },
          {
            "match": "유형=매매/공급",
            "result": "필수: 목적물·대금·인도및검수·하자담보·기간·해지·관할"
          },
          {
            "match": "유형=임대차",
            "result": "필수: 임대목적물·임대료·기간·보증금·원상복구·해지·관할"
          },
          {
            "match": "유형=NDA(비밀유지)",
            "result": "필수: 비밀정보정의·이용목적제한·유지기간·반환파기·위반시구제"
          }
        ]
      },
      {
        "id": "lt_approval_line",
        "description": "금액 구간별 결재선(B사 2단계 단순결재 담당→대표 반영). 모든 건은 최종 대표 결재로 종착, 자동승인 가능 건만 담당 단독 종결 허용.",
        "entries": [
          {
            "match": "amount < 500만원 AND riskGrade=low",
            "result": "결재선=[담당](자동승인 가능·담당 확인 종결)"
          },
          {
            "match": "500만원 <= amount < 3000만원 AND riskGrade!=high",
            "result": "결재선=[담당 → 대표]"
          },
          {
            "match": "amount >= 3000만원 OR riskGrade=high OR 법무플래그 존재",
            "result": "결재선=[담당 → 법무검토(HITL) → 대표]"
          }
        ]
      },
