        "flag": "배상한도_과다_핵심플래그"
      },
      {
        "id": "th_penalty_rate",
        "expr": "penaltyClauseRate > 0.10",
        "flag": "위약벌_과도"
      },
      {
        "id": "th_extract_confidence",
        "expr": "extractConfidence < 0.7",
        "flag": "추출신뢰도_저하_HITL이관"
      },
      {
        "id": "th_renewal_notice_short",
        "expr": "noticePeriodDays < 30 AND autoRenewalClause 존재",
        "flag": "거절통지기한_단기_독소"
      },
      {
        "id": "th_stamp_tax_threshold",
        "expr": "contractAmount > 10000000",
        "flag": "인지세_과세대상"
      }
    ]
