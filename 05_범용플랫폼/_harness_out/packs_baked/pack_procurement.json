    "decisionTables": [
      {
        "id": "dt_route",
        "description": "최종 분기 라우팅: 자동승인 / 구매검토(HITL) / 반려. 우선순위 = 하드위반(반려) > 플래그(검토) > 전PASS(자동승인). 보수 risk appetite상 경계 케이스는 검토로 기움.",
        "rules": [
          {
            "when": "budget_after_order < 0",
            "then": "반려 (예산 초과 발주 금지 — 하드 가드레일)"
          },
          {
            "when": "vendor_status IN ('제재','거래정지') OR vendor_biz_no_valid == false",
            "then": "반려 (벤더 컴플라이언스 하드 차단)"
          },
          {
            "when": "order_amount >= 5000000 AND purchase_type != '단가계약' AND quote_count < 3",
            "then": "반려 (3견적 의무 미충족·보완요청)"
          },
          {
            "when": "spec_attached == false OR quote_valid_until < today",
            "then": "반려 (증빙 미충족·보완요청)"
          },
          {
            "when": "split_score >= split_score_review_threshold",
            "then": "구매검토(HITL) — 쪼개기 의심, 자동승인 차단 (구매팀장 의도 판정)"
          },
          {
            "when": "is_new_vendor == true",
            "then": "구매검토(HITL) — 신규 벤더 실사 수기 확인(구매 담당자)"
          },
          {
            "when": "unit_price_deviation_pct > unit_price_deviation_threshold",
            "then": "구매검토(HITL) — 단가 편차 초과(편차 사유 정당성 판단)"
          },
          {
            "when": "budget_usage_pct >= budget_usage_review_threshold",
            "then": "구매검토(HITL) — 예산 임박 승급(보수 risk appetite)"
          },
          {
            "when": "quote_extract_confidence < quote_confidence_threshold OR spec_match == '모호'",
            "then": "구매검토(HITL) — 견적 추출·사양 일치 사람 확인"
          },
          {
            "when": "모든 결정론 점검 PASS AND order_amount <= auto_approve_amount_cap",
            "then": "자동승인 (저위험·소액·규정 충족)"
          },
          {
            "when": "모든 결정론 점검 PASS AND order_amount > auto_approve_amount_cap",
            "then": "구매검토(HITL) — 점검은 PASS이나 고액이라 결재선 승인 필요"
          }
        ]
      },
      {
        "id": "dt_writeback",
        "description": "승인·반려 확정 후 ERP 반영 분기 (po_writeback). 온프레미스 전용 — 사내 경계 내 처리.",
        "rules": [
          {
            "when": "route == '자동승인' OR (route == '구매검토' AND 결재 완료)",
            "then": "SAP MM PO 생성 + FI 예산 commitment 약정 + 전자조달 발주상태 반영 + 감사로그 적재"
          },
          {
            "when": "ERP 약정 실패(commitment_status == 'fail')",
            "then": "PO 롤백·재시도, 실패 지속 시 구매검토 회부"
          },
          {
            "when": "route == '반려'",
            "then": "전자조달에 반려상태 반영 + 보완사유 현업 회신(초안 LLM·발송 전 검토) + 감사로그 적재"
          }
        ]
      }
    ],
    "thresholds": [
      {
        "id": "auto_approve_amount_cap",
        "expr": "order_amount <= 5000000",
        "flag": "자동승인 금액 상한(팀장 위임전결 구간·저위험 소액). 초과는 점검 PASS여도 결재선 검토."
      },
      {
        "id": "approval_line_t1",
        "expr": "order_amount <= 5000000",
        "flag": "결재선=팀장"
      },
      {
        "id": "approval_line_t2",
        "expr": "order_amount <= 50000000",
        "flag": "결재선=구매팀장"
      },
      {
        "id": "approval_line_t3",
        "expr": "order_amount <= 300000000",
        "flag": "결재선=본부장"
      },
      {
        "id": "approval_line_t4",
        "expr": "order_amount > 300000000",
        "flag": "결재선=CPO"
      },
      {
        "id": "three_quote_threshold",
        "expr": "order_amount >= 5000000 AND purchase_type != '단가계약'",
        "flag": "3견적 의무 적용"
      },
      {
        "id": "budget_block",
        "expr": "budget_after_order < 0",
        "flag": "예산 초과 — 하드 반려(절대 규칙)"
      },
      {
        "id": "budget_usage_review_threshold",
        "expr": "budget_usage_pct >= 90",
        "flag": "예산 임박 — 검토 승급(보수 risk appetite, 90% 소진)"
      },
      {
        "id": "unit_price_deviation_threshold",
        "expr": "unit_price_deviation_pct > 10",
        "flag": "단가계약 편차 초과 — 검토(허용 편차 10% 가정)"
      },
      {
        "id": "split_score_review_threshold",
        "expr": "split_score >= 70",
        "flag": "쪼개기 의심 — 검토 강제 승급(보수 risk appetite, 0~100 스코어)"
      },
      {
        "id": "split_proximity_window",
        "expr": "동일 요청자·예산코드 발주 간격 <= 14일",
        "flag": "쪼개기 근접 기간 신호(14일 내)"
      },
      {
        "id": "split_near_threshold_band",
        "expr": "order_amount >= 임계*0.9 AND order_amount < 임계 (5M/50M/300M 직하)",
        "flag": "임계 직하 금액 반복 신호(임계의 90~100%)"
      },
      {
        "id": "quote_confidence_threshold",
        "expr": "quote_extract_confidence < 0.8",
        "flag": "견적 추출 신뢰도 미달 — 사람 확인 플래그"
      }
    ]
  },
