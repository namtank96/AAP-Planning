{
  "id": "subsidy",
  "label": "보조금·지원금 심사",
  "flow": [
    {
      "id": "sp1",
      "label": "신청 접수·서류 완전성 점검",
      "kind": "input",
      "loopPhase": "Data",
      "explain": "e나라도움에서 신청 건 수신(공모당 3,000건 배치+상시). 신청서·증빙PDF 수집, 필수서류 목록 대비 누락·서식·유효기간(사업자등록증·납세증명·재무제표 등) 자동 체크. 누락 시 보완 요청 분기, 완전 시 자격심사로 이관. 구조화 데이터(자격요건·예산현황·수급이력) 매핑."
    },
    {
      "id": "sp2",
      "label": "자격요건 자동 검증",
      "kind": "auto",
      "loopPhase": "Data",
      "explain": "행정정보공동이용 사업자/자격DB·e나라도움 조회로 업종(표준산업분류 매칭)·기업규모(매출·상시근로자)·소재지(지역 요건)·사업이력(업력·기존 지원 이력)을 공모 자격기준과 결정론적으로 대조. 각 요건 PASS/FAIL/판단필요 산출. read-only DB라 사실 대조는 자동, 코드 경계 케이스는 플래그."
    },
    {
      "id": "sp3",
      "label": "중복수급·부정수급 이력 점검",
      "kind": "auto",
      "loopPhase": "Data",
      "explain": "수급이력 DB·e나라도움 교차조회로 동일 사업·동일 목적 중복신청, 타 부처·지자체 동일 보조금 중복수급, 과거 환수·제재·부정수급 이력, 부도·체납 상태를 점검. 엄격 리스크 성향 반영해 중복·부정 신호는 적극 차단(반려 또는 SIU성 정밀검토 이관). '중복수급 금지' 제약 강제."
    },
    {
      "id": "sp4",
      "label": "예산 잔액 점검·교부 가능성 판정",
      "kind": "auto",
      "loopPhase": "Data",
      "explain": "e나라도움 예산현황 조회로 해당 사업 예산 잔액 대비 신청(요청)액 점검. '예산 초과 교부 금지' 제약 강제 — 잔액 부족 시 교부 보류·순위 대기·감액 검토. 신청액과 단가·한도 기준 대조해 교부 가능액 산정."
    },
    {
      "id": "sp5",
      "label": "심사 분기 라우팅(자동승인/HITL/반려)",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "sp2~sp4 종합으로 분기: 모든 정량요건 충족+무위험+예산내 → 자동승인 후보 / 정성평가(사업계획 적정성, 데이터 gap) 또는 경계·재량 건 → 심사위원 검토(HITL) / 명백한 자격미달·중복·부정·서류미비 → 반려. 정성평가가 데이터 gap이라 적정성은 반드시 사람 판단으로 이관.",
      "gate": {
        "label": "심사 분기 라우팅(자동승인/HITL/반려)",
        "decisions": [
          {
            "key": "LEGAL_REVIEW",
            "label": "LEGAL_REVIEW",
            "toast": "LEGAL_REVIEW"
          },
          {
            "key": "REJECT",
            "label": "REJECT",
            "toast": "REJECT"
          },
          {
            "key": "AUTO_APPROVE",
            "label": "AUTO_APPROVE",
            "toast": "AUTO_APPROVE"
          }
        ]
      },
      "next": {
        "LEGAL_REVIEW": "review",
        "REJECT": "reject",
        "AUTO_APPROVE": "commit"
      },
      "nextBy": "evaluate(caseData, knowledge).outcome"
    },
    {
      "id": "sp6",
      "label": "전결권 기반 승인·교부 결정",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "승인 금액에 따라 전결 라우팅: 담당 500만원 이하·팀장 5천만원 이하·초과는 심사위원회 의결. 승인자가 자격·예산·위험 점검 결과를 검토하고 교부 결정(승인/조건부승인/감액/반려) 확정. 권한 경계 강제(권한 초과 자동 승인 금지)."
    },
    {
      "id": "sp7",
      "label": "교부 결정 반영·예산 차감·기록",
      "kind": "auto",
      "loopPhase": "Decision",
      "explain": "확정된 교부 결정을 e나라도움에 writeback(교부 결정 등록·예산 차감·신청 상태 갱신), 신청인 통지(승인·반려·보완 사유), 결정 근거·점검 이력·심사 의견을 감사 추적 로그로 기록. 예산 차감으로 후속 신청의 예산 잔액에 실시간 반영. 부정·환수 사유 발생 시 사후관리 트리거."
    }
  ],
  "io": {
    "inputs": [
      {
        "stage": "sp1",
        "type": "file",
        "key": "requiredDocsStatus",
        "label": "필수서류 제출/누락 목록"
