{
  "id": "contract_A",
  "label": "계약 A사",
  "flow": [
    {
      "id": "sp1",
      "label": "계약 건 접수·유형 분류",
      "kind": "input",
      "loopPhase": "Data",
      "explain": "현업/구매가 신규·갱신·변경 건을 접수하면 계약유형(매매·용역·임대·NDA·MOU 등)·거래처·금액·기간을 식별하고 계약마스터에 신규 케이스를 생성한다(월 80건 인입)."
    },
    {
      "id": "sp2",
      "label": "문서 수집·핵심정보 추출",
      "kind": "auto",
      "loopPhase": "Data",
      "explain": "SharePoint의 계약서 PDF를 수집하고 금액·기간·자동갱신·통지기한·관할·준거법 등 핵심 메타데이터를 추출해 구조화한다(스캔/이미지 PDF는 추출 신뢰도 저하 가능)."
    },
    {
      "id": "sp3",
      "label": "필수조항 누락 점검",
      "kind": "auto",
      "loopPhase": "Semantic",
      "explain": "계약유형별 필수조항 체크리스트(손해배상·해지·비밀유지·관할·준거법·하자담보 등)와 대조해 누락 항목을 식별한다(규정 기반 결정론 판정)."
    },
    {
      "id": "sp4",
      "label": "표준템플릿 편차 대조",
      "kind": "auto",
      "loopPhase": "Decision",
      "explain": "자사 표준계약서 대비 조항 변경·삭제·추가를 대조하나, A사 표준템플릿이 디지털화 안 됨(데이터 갭)으로 자동대조 불가 → 편차 의심 시 법무검토로 우회한다."
    },
    {
      "id": "sp5",
      "label": "독소(위험)조항 탐지",
      "kind": "auto",
      "loopPhase": "Reasoning",
      "explain": "무제한 손해배상·일방 해지·과도한 위약벌·자동갱신 독소·관할 불리·지재권 양도 등 위험조항을 패턴/규칙으로 탐지하고 위험등급을 산정한다(룰 기반 1차, 신종/문맥의존은 HITL)."
    },
    {
      "id": "sp6",
      "label": "금액·위임전결 결재선 산정",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "계약금액을 위임전결 구간(팀장 10M·본부장 100M·CFO 500M·대표 초과)에 매핑해 결재선을 자동 구성한다(금액 구간 결정론 매핑, 제조업 발주연동 금액 ERP FI 대조).",
      "gate": {
        "label": "금액·위임전결 결재선 산정",
        "decisions": [
          {
            "key": "REJECT",
            "label": "REJECT",
            "toast": "REJECT"
          },
          {
            "key": "LEGAL_REVIEW",
            "label": "LEGAL_REVIEW",
            "toast": "LEGAL_REVIEW"
          },
          {
            "key": "AUTO_APPROVE",
            "label": "AUTO_APPROVE",
            "toast": "AUTO_APPROVE"
          }
        ]
      },
      "next": {
        "REJECT": "reject",
        "LEGAL_REVIEW": "review",
        "AUTO_APPROVE": "commit"
      },
      "nextBy": "evaluate(caseData, knowledge).outcome"
    },
    {
      "id": "sp7",
      "label": "만기·자동갱신·통지기한 점검",
      "kind": "auto",
      "loopPhase": "Data",
      "explain": "계약기간·만기일·자동갱신 여부·갱신거절 통지기한을 추출해 통지 데드라인을 산정하고 알림 일정을 등록한다(날짜 산술=결정론)."
    },
    {
      "id": "sp8",
      "label": "인지세·법정요건 점검",
      "kind": "auto",
      "loopPhase": "Reasoning",
      "explain": "계약유형·금액에 따른 인지세 과세대상 여부·세액을 산정하고 전자계약 인지세 요건을 점검한다(과세표·금액 기준 결정론)."
    },
    {
      "id": "sp9",
      "label": "거래처 제재·신용 리스크 점검",
      "kind": "auto",
      "loopPhase": "Reasoning",
      "explain": "거래처마스터·ERP와 대조해 제재리스트·거래정지·신용등급·중복거래처를 점검한다(제재리스트 매칭=결정론, 평판·간접 리스크=HITL)."
    },
    {
      "id": "sp10",
      "label": "분기 판정(자동승인/법무검토/반려)",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "점검 결과를 종합해 보수적 임계(낮은 위험 허용도)로 자동승인·법무검토(HITL)·반려를 분기한다 — A사 리스크 성향상 경계 건은 폭넓게 법무검토로 회부.",
      "gate": {
        "label": "분기 판정(자동승인/법무검토/반려)",
        "decisions": [
          {
            "key": "REJECT",
            "label": "REJECT",
            "toast": "REJECT"
          },
          {
            "key": "LEGAL_REVIEW",
            "label": "LEGAL_REVIEW",
            "toast": "LEGAL_REVIEW"
          },
          {
            "key": "AUTO_APPROVE",
            "label": "AUTO_APPROVE",
            "toast": "AUTO_APPROVE"
          }
        ]
      },
      "next": {
        "REJECT": "reject",
        "LEGAL_REVIEW": "review",
        "AUTO_APPROVE": "commit"
      },
      "nextBy": "evaluate(caseData, knowledge).outcome"
    },
    {
      "id": "sp11",
      "label": "법무 심층검토(HITL)",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "자동대조 불가한 템플릿 편차·신종 독소조항·문맥의존 위험·고액/비표준 건을 법무팀이 심층 검토하고 수정요청·조건부승인·반려를 결정한다."
    },
    {
      "id": "sp12",
      "label": "결재·체결 진행",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "확정된 위임전결 결재선을 따라 전자결재를 상신·승인받고 서명·체결을 진행한다(온프레미스 결재, 국외이전 금지 준수)."
    },
    {
      "id": "sp13",
      "label": "계약관리대장 등록·후속 알림",
      "kind": "auto",
      "loopPhase": "Learning",
      "explain": "체결 완료 건을 자체구축 계약관리 시스템 대장에 등록(read-write)하고 만기·갱신통지 알림과 사후 모니터링을 활성화한다."
    }
  ],
