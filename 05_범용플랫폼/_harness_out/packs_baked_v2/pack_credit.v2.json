{
  "id": "credit",
  "label": "여신·한도 심사",
  "flow": [
    {
      "id": "intake",
      "label": "신청 접수·자료 수집",
      "kind": "input",
      "loopPhase": "Data",
      "explain": "대출·한도 신청 접수 → 신청금액·목적·기간·담보 유형 파악. 여신코어에서 기존 거래·여신 잔액 조회(read-write), CB사 API로 신용등급·부채현황(read), 소득증빙 PDF 수령. 비정형 소득(프리랜서) 추정 일부는 수기 보완(데이터 갭)."
    },
    {
      "id": "kyc_aml",
      "label": "KYC·제재·자금세탁 점검",
      "kind": "auto",
      "loopPhase": "Decision",
      "explain": "실명DB 대조, 제재리스트 스크리닝, 자금세탁 위험 점검(KYC/AML API, read). 제재 대상 적중 시 즉시 거래 차단(constraint: 제재 대상 거래 금지). 경계·의심 건은 준법·AML 담당 검토로 이관."
    },
    {
      "id": "credit_assess",
      "label": "소득·부채·담보·신용 분석",
      "kind": "auto",
      "loopPhase": "Semantic",
      "explain": "소득증빙 정규화, 부채현황·연체이력·담보평가 통합. 신용등급 컷, 기존 연체/부실 여부, 소득증빙 충족도 산출. 결정론 규칙으로 신청인 리스크 프로파일 구성(L4 온톨로지: 신청인-신청-담보-신용 객체)."
    },
    {
      "id": "limit_calc",
      "label": "DSR/LTV 한도·규제 산정",
      "kind": "auto",
      "loopPhase": "Decision",
      "explain": "DSR(총부채원리금상환비율) 한도 계산, 담보 LTV 한도 계산, 금융규제 DSR 한도 준수 검증. 엄격 리스크 성향에 따라 보수·경계값 적용. 산정 한도와 신청금액 대조로 충족/초과 판정."
    },
    {
      "id": "route_decision",
      "label": "분기 판정(자동승인/HITL/반려)",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "전 점검 결과를 종합해 자동승인 / 여신심사역 검토(HITL) / 반려로 분기. 모든 컷·KYC·소득·연체·규제 PASS이고 명확하면 자동승인, 경계·예외·소명 필요 건은 심사역 검토, 컷 미달·제재·규제 초과는 반려.",
      "gate": {
        "label": "분기 판정(자동승인/HITL/반려)",
        "decisions": [
          {
            "key": "REJECT",
            "label": "REJECT",
            "toast": "REJECT"
          },
          {
            "key": "LEGAL_REVIEW",
            "label": "LEGAL_REVIEW",
            "toast": "LEGAL_REVIEW"
          },
          {
            "key": "AUTO_APPROVE",
            "label": "AUTO_APPROVE",
            "toast": "AUTO_APPROVE"
          }
        ]
      },
      "next": {
        "REJECT": "reject",
        "LEGAL_REVIEW": "review",
        "AUTO_APPROVE": "commit"
      },
      "nextBy": "evaluate(caseData, knowledge).outcome"
    },
    {
      "id": "delegation_approve",
      "label": "위임전결 승인",
      "kind": "gate",
      "loopPhase": "Decision",
      "explain": "심사역 검토 통과 건은 금액·등급별 위임전결로 승인자 라우팅(심사역 5천만·팀장 2억·부장 10억·여신위 초과). 권한 한도 내에서 승인, 초과 시 상위 결재·여신위 의결 이관."
    },
    {
      "id": "register",
      "label": "한도 약정·여신원장 등록",
      "kind": "auto",
      "loopPhase": "Decision",
      "explain": "승인 건은 한도 약정 체결, 여신코어에 여신원장 등록(read-write). 약정 한도·조건 반영, 처리 결과·근거 기록. 반려 건은 사유 통지 및 종결."
    }
  ],
