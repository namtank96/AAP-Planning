  "knowledge": {
    "route": {
      "rules": [
        {
          "id": "r1_sanction_block",
          "outcome": "REJECT",
          "label": "제재 대상 거래 차단",
          "basis": "sanctionHit = true → 반려 (제재 대상 거래 금지 — 제약 위반, 즉시 차단)",
          "when": {
            "==": [
              "$sanctionHit",
              true
            ]
          }
        },
        {
          "id": "r2_aml_review",
          "outcome": "LEGAL_REVIEW",
          "label": "AML·실명 불일치 준법 이관",
          "basis": "amlRiskLevel = 고 OR 실명 불일치 → 심사역검토(HITL) — 준법·AML 담당 이관",
          "when": {
            "any": [
              {
                "==": [
                  "$amlRiskLevel",
                  "고"
                ]
              },
              {
                "==": [
                  "$incomeProofComplete",
                  false
                ]
              }
            ]
          }
        },
        {
          "id": "r3_default_reject",
          "outcome": "REJECT",
          "label": "부실 보유 반려",
          "basis": "defaultFlag = true (부실 보유) → 반려 (부도·대위변제 이력)",
          "when": {
            "==": [
              "$defaultFlag",
              true
            ]
          }
        },
        {
          "id": "r4_credit_cut_reject",
          "outcome": "REJECT",
          "label": "신용등급 컷 미달 반려",
          "basis": "creditGrade >= 7 (컷 미달) → 반려 (신용등급 컷 미달)",
          "when": {
            ">=": [
              "$creditGrade",
              7
            ]
          }
        },
        {
          "id": "r5_dsr_over_reject",
          "outcome": "REJECT",
          "label": "DSR 규제 한도 초과 반려",
          "basis": "dsrRatio > 40 (규제 상한 초과) → 반려 (DSR 규제 한도 초과)",
          "when": {
            ">": [
              "$dsrRatio",
              40
            ]
          }
        },
        {
          "id": "r6_over_limit_review",
          "outcome": "LEGAL_REVIEW",
          "label": "한도 초과 심사역 검토",
          "basis": "requestAmount > approvedLimit (한도 초과) → 심사역검토(HITL) — 한도 내 조정 또는 부결 판단",
          "when": {
            ">": [
              "$requestAmount",
              "$approvedLimit"
            ]
          }
        },
        {
          "id": "r7_soundness_review",
          "outcome": "LEGAL_REVIEW",
          "label": "연체·소명·추정소득 검토",
          "basis": "delinquencyHistory = 있음(최근 연체) OR incomeProofComplete = false OR incomeType = 프리랜서 → 심사역검토(HITL) — 소명·추정 검토",
          "when": {
            "any": [
              {
                "==": [
                  "$delinquencyHistory",
                  "있음"
                ]
              },
              {
                "==": [
                  "$incomeProofComplete",
                  false
                ]
              },
              {
                "==": [
                  "$incomeType",
                  "프리랜서"
                ]
              }
            ]
          }
        },
        {
          "id": "r8_boundary_review",
          "outcome": "LEGAL_REVIEW",
          "label": "경계값 보수 검토",
          "basis": "creditGrade in 5~6 (경계) OR dsrRatio in 33~35 OR ltvRatio in 55~60 (경계 근접) → 심사역검토(HITL) — 경계값 보수 검토",
          "when": {
            "any": [
              {
                "in": [
                  "$creditGrade",
                  [
                    5,
                    6
                  ]
                ]
              },
              {
                "all": [
                  {
                    ">=": [
                      "$dsrRatio",
                      33
                    ]
                  },
                  {
                    "<=": [
                      "$dsrRatio",
                      35
                    ]
                  }
                ]
              },
              {
                "all": [
                  {
                    ">=": [
                      "$ltvRatio",
                      55
                    ]
                  },
                  {
                    "<=": [
                      "$ltvRatio",
                      60
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "id": "r9_auto_approve",
          "outcome": "AUTO_APPROVE",
          "label": "전 컷 PASS 자동승인",
          "basis": "sanctionHit=false AND amlRiskLevel=저 AND defaultFlag=false AND creditGrade<=4 AND delinquencyHistory=없음 AND incomeProofComplete=true AND dsrRatio<=33 AND ltvRatio<=55 AND requestAmount<=approvedLimit → 자동승인 (전 컷 PASS·명확건) → 위임전결 결재선 라우팅",
          "when": {
            "all": [
              {
                "==": [
                  "$sanctionHit",
                  false
                ]
              },
              {
                "==": [
                  "$amlRiskLevel",
                  "저"
                ]
              },
              {
                "==": [
                  "$defaultFlag",
                  false
                ]
              },
              {
                "<=": [
                  "$creditGrade",
                  4
                ]
              },
              {
                "==": [
                  "$delinquencyHistory",
                  "없음"
                ]
              },
              {
                "==": [
                  "$incomeProofComplete",
                  true
                ]
              },
              {
                "<=": [
                  "$dsrRatio",
                  33
                ]
              },
              {
                "<=": [
                  "$ltvRatio",
                  55
                ]
              },
              {
                "<=": [
                  "$requestAmount",
                  "$approvedLimit"
                ]
              }
            ]
          }
        }
      ],
      "default": {
        "id": "fallback_review",
        "outcome": "LEGAL_REVIEW",
        "label": "미분류건 심사역 검토",
        "basis": "위 룰에 해당하지 않는 모든 케이스(전 컷 PASS도 아니고 명시적 차단·반려·검토 사유도 아닌 미분류건)는 보수적으로 심사역검토(HITL)로 라우팅"
      }
    },
    "lookupTables": [
      {
        "id": "lt_delegation",
        "description": "금액·등급별 위임전결 결재선 라우팅(policy: 심사역5천만·팀장2억·부장10억·여신위 초과). 신청금액→결재권자 결정론 매핑.",
        "entries": [
          {
            "match": "requestAmount <= 50,000,000",
            "result": "심사역 전결"
          },
          {
            "match": "50,000,000 < requestAmount <= 200,000,000",
            "result": "팀장 전결"
          },
          {
            "match": "200,000,000 < requestAmount <= 1,000,000,000",
            "result": "부장 전결"
          },
          {
            "match": "requestAmount > 1,000,000,000",
            "result": "여신위원회 의결"
          }
        ]
      },
      {
        "id": "lt_grade_cut",
        "description": "신용등급 컷 라벨(엄격 리스크 성향 반영). CB 신용등급(1~10)→처리경로 매핑. 컷 미달은 반려, 경계등급은 심사역 검토.",
        "entries": [
          {
            "match": "creditGrade 1~4 (우량)",
            "result": "등급 PASS — 자동심사 가능"
          },
          {
            "match": "creditGrade 5~6 (경계)",
            "result": "등급 경계 — 심사역 검토(HITL)"
          },
          {
            "match": "creditGrade 7~10 (컷 미달)",
            "result": "등급 FAIL — 반려"
          }
        ]
      },
      {
        "id": "lt_ltv_limit",
        "description": "담보유형별 LTV 한도(엄격 성향: 규제 대비 보수 적용). 담보평가액×한도율=최대 담보인정금액.",
        "entries": [
          {
            "match": "collateralType=부동산(아파트)",
            "result": "LTV 한도 60% (엄격 보수)"
          },
          {
            "match": "collateralType=부동산(비주거)",
            "result": "LTV 한도 50%"
          },
          {
            "match": "collateralType=무담보(신용)",
            "result": "LTV 미적용 — 소득·DSR 기준 한도"
          }
        ]
      },
      {
        "id": "lt_dsr_cap",
        "description": "규제·정책 DSR 상한(엄격 성향: 규제 한도보다 보수적 운용). DSR이 상한 초과 시 한도 축소 또는 반려.",
        "entries": [
          {
            "match": "규제 DSR 상한(금융규제)",
            "result": "40%"
          },
          {
            "match": "기관 내부 보수 DSR 상한(엄격)",
            "result": "35%"
          },
          {
            "match": "경계 검토 구간",
            "result": "33% ~ 35%"
          }
        ]
      },
      {
        "id": "lt_income_proof",
        "description": "소득유형별 증빙 인정 기준. 정형 소득은 규칙 인정, 비정형(프리랜서)은 보수 추정·심사역 보완(데이터 갭).",
        "entries": [
          {
            "match": "incomeType=근로소득(원천징수)",
            "result": "증빙 100% 인정"
          },
          {
            "match": "incomeType=사업소득(소득금액증명)",
            "result": "증빙 100% 인정"
          },
          {
            "match": "incomeType=프리랜서(비정형)",
            "result": "보수 추정 — 수기 보완·심사역 HITL"
          }
        ]
      }
    ],
    "thresholds": [
      {
        "id": "th_dsr_regulatory",
        "expr": "dsrRatio > 40",
        "flag": "DSR_REGULATORY_EXCEED (규제 상한 초과 → 반려)"
      },
      {
        "id": "th_dsr_conservative",
        "expr": "dsrRatio > 35",
        "flag": "DSR_CONSERVATIVE_EXCEED (엄격 보수 상한 초과 → 한도축소·검토)"
      },
      {
        "id": "th_dsr_border",
        "expr": "dsrRatio >= 33 AND dsrRatio <= 35",
        "flag": "DSR_BORDERLINE (경계 검토 → HITL)"
      },
      {
        "id": "th_ltv_cap",
        "expr": "ltvRatio > 60",
        "flag": "LTV_EXCEED (담보 LTV 한도 초과 → 한도축소·반려)"
      },
      {
        "id": "th_ltv_border",
        "expr": "ltvRatio >= 55 AND ltvRatio <= 60",
        "flag": "LTV_BORDERLINE (경계 근접 → 보수 검토 HITL)"
      },
      {
        "id": "th_grade_cut",
        "expr": "creditGrade >= 7",
        "flag": "GRADE_CUT_FAIL (신용등급 컷 미달 → 반려)"
      },
      {
        "id": "th_grade_border",
        "expr": "creditGrade >= 5 AND creditGrade <= 6",
        "flag": "GRADE_BORDERLINE (경계 등급 → HITL)"
      },
      {
        "id": "th_delegation_staff",
        "expr": "requestAmount <= 50000000",
        "flag": "APPROVE_STAFF (심사역 전결)"
      },
      {
        "id": "th_delegation_team",
        "expr": "requestAmount > 50000000 AND requestAmount <= 200000000",
        "flag": "APPROVE_TEAMLEAD (팀장 전결)"
      },
      {
        "id": "th_delegation_dept",
        "expr": "requestAmount > 200000000 AND requestAmount <= 1000000000",
        "flag": "APPROVE_DEPTHEAD (부장 전결)"
      },
      {
        "id": "th_delegation_committee",
        "expr": "requestAmount > 1000000000",
        "flag": "APPROVE_COMMITTEE (여신위원회 의결)"
      },
      {
        "id": "th_sanction",
        "expr": "sanctionHit = true",
        "flag": "SANCTION_BLOCK (제재 적중 → 거래 금지·반려)"
      },
      {
        "id": "th_default",
        "expr": "defaultFlag = true",
        "flag": "DEFAULT_HELD (부실 보유 → 반려)"
      }
    ]
  },
