  "knowledge": {
    "route": {
      "rules": [
        {
          "id": "r1_sanction_gap",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(HITL) — 제재 데이터 갭",
          "basis": "제재 스크리닝 결과가 미확인이거나 제재 대상 적중 시 수기 확인 필수 보강(해당 시 반려 검토). sanctionCheckResult(표시) 대신 명시 슬롯 sanctionListHit으로 분기.",
          "when": {
            "in": [
              "$sanctionListHit",
              [
                "unknown",
                "hit"
              ]
            ]
          }
        },
        {
          "id": "r2_missing_mandatory_clause",
          "outcome": "REJECT",
          "label": "반려 — 필수조항 누락",
          "basis": "필수조항 누락 항목이 존재하면 보완 후 재접수. requiredClausesPresent(표시) 대신 누락 목록 슬롯 missingMandatoryClauses의 비어있지 않음으로 분기.",
          "when": {
            "not": {
              "empty": "$missingMandatoryClauses"
            }
          }
        },
        {
          "id": "r3_low_confidence_or_unparseable",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(HITL) — 비정형 조항 해석 이관",
          "basis": "추출 신뢰도 0.7 미만이거나 비표준 조항 해석 불가 시 해석 이관. extractConfidence(표시) 대신 명시 슬롯 pdfExtractConfidence와 templateDigitalized(=false: 디지털화 안 됨=해석 불가)로 분기.",
          "when": {
            "any": [
              {
                "<": [
                  "$pdfExtractConfidence",
                  0.7
                ]
              },
              {
                "==": [
                  "$templateDigitalized",
                  false
                ]
              }
            ]
          }
        },
        {
          "id": "r4_toxic_high_flag",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(HITL) — 독소조항 실질위험 전문판단",
          "basis": "위험=high 핵심 독소조항 플래그가 1건 이상이면 전문판단 회부. toxicClauseFlags(표시) 대신 명시 슬롯 toxicHighCount(>0) 또는 toxicUnmatched(미매칭=해석 불가)로 분기.",
          "when": {
            "any": [
              {
                ">": [
                  "$toxicHighCount",
                  0
                ]
              },
              {
                "not": {
                  "empty": "$toxicUnmatched"
                }
              }
            ]
          }
        },
        {
          "id": "r5_template_critical_deviation",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(HITL) — 편차 수용 가능성 판단",
          "basis": "표준 템플릿 대비 편차=중대 항목이 존재하면 수용 가능성 판단 회부. templateDeviationItems(표시) 대신 명시 슬롯 templateDeviationItems의 severity 중대 교집합으로 분기.",
          "when": {
            "intersects": [
              "$templateDeviationItems",
              [
                "critical",
                "중대"
              ]
            ]
          }
        },
        {
          "id": "r6_high_amount",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(HITL) → 대표 결재 — 고액 건 핵심위험 점검",
          "basis": "계약금액 3천만원 이상 고액 건은 법무검토 후 대표 결재. contractAmount는 명시 금액 슬롯이라 직접 사용.",
          "when": {
            ">=": [
              "$contractAmount",
              30000000
            ]
          }
        },
        {
          "id": "r7_auto_approve",
          "outcome": "AUTO_APPROVE",
          "label": "자동승인 — 담당 확인 종결",
          "basis": "저위험·고액 미만·필수조항 완비·핵심플래그 없음·제재 비해당이면 담당 확인 후 자동 종결(대표 결재 생략 가능). riskGrade(표시) 대신 compositeRiskScore(저위험 임계 <30)·contractAmount(고액 임계 미만 <30000000)·missingMandatoryClauses 빈값·toxicHighCount 0·toxicUnmatched 빈값·sanctionListHit none으로 분기. (소액·중간금액 정상 건 모두 자동승인 흡수하도록 고액 임계 미만으로 상향, 회색지대 누출 방지)",
          "when": {
            "all": [
              {
                "<": [
                  "$compositeRiskScore",
                  30
                ]
              },
              {
                "<": [
                  "$contractAmount",
                  30000000
                ]
              },
              {
                "empty": "$missingMandatoryClauses"
              },
              {
                "==": [
                  "$toxicHighCount",
                  0
                ]
              },
              {
                "empty": "$toxicUnmatched"
              },
              {
                "==": [
                  "$sanctionListHit",
                  "none"
                ]
              }
            ]
          }
        }
      ],
      "default": {
        "id": "r8_gray_zone",
        "outcome": "LEGAL_REVIEW",
        "label": "법무검토(HITL) 생략 가능 시 담당 → 대표 결재",
        "basis": "그 외 회색지대 전부. 중도 성향으로 회색지대는 대표 결재로 흡수하고 핵심위험만 법무 회부. 앞 룰에 걸리지 않은 모든 건을 흡수하는 catch-all이므로 rules가 아닌 fallback으로 배치."
      }
    },
