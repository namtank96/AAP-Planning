      },
      {
        "key": "auto_approve_amount_cap"
      }
    ]
  },
  "knowledge": {
    "route": {
      "rules": [
        {
          "id": "R01_budget_overrun",
          "outcome": "REJECT",
          "label": "반려 (예산 초과 발주 금지 — 하드 가드레일)",
          "basis": "발주 후 잔여예산이 음수이면 예산 초과 발주로 하드 차단",
          "when": {
            "<": [
              "$budget_after_order",
              0
            ]
          }
        },
        {
          "id": "R02_vendor_compliance_block",
          "outcome": "REJECT",
          "label": "반려 (벤더 컴플라이언스 하드 차단)",
          "basis": "벤더가 제재·거래정지 상태이거나 사업자번호가 유효하지 않으면 하드 차단",
          "when": {
            "any": [
              {
                "in": [
                  "$vendor_status",
                  [
                    "제재",
                    "거래정지"
                  ]
                ]
              },
              {
                "==": [
                  "$vendor_biz_no_valid",
                  false
                ]
              }
            ]
          }
        },
        {
          "id": "R03_three_quote_required",
          "outcome": "REJECT",
          "label": "반려 (3견적 의무 미충족·보완요청)",
          "basis": "발주금액 500만원 이상·단가계약이 아니면서 견적이 3건 미만이면 3견적 의무 미충족",
          "when": {
            "all": [
              {
                ">=": [
                  "$order_amount",
                  5000000
                ]
              },
              {
                "!=": [
                  "$purchase_type",
                  "단가계약"
                ]
              },
              {
                "<": [
                  "$quote_count",
                  3
                ]
              }
            ]
          }
        },
        {
          "id": "R04_evidence_missing",
          "outcome": "REJECT",
          "label": "반려 (증빙 미충족·보완요청)",
          "basis": "사양서 미첨부이거나 견적 유효기한이 오늘 이전이면 증빙 미충족",
          "when": {
            "any": [
              {
                "==": [
                  "$spec_attached",
                  false
                ]
              },
              {
                "<": [
                  "$quote_valid_until",
                  "$today"
                ]
              }
            ]
          }
        },
        {
          "id": "R05_split_suspect",
          "outcome": "LEGAL_REVIEW",
          "label": "구매검토(HITL) — 쪼개기 의심, 결재 회부 (구매팀장 의도 판정)",
          "basis": "쪼개기 점수가 검토 임계 이상이면 자동 처리를 막고 의도 판정",
          "when": {
            ">=": [
              "$split_score",
              "$split_score_review_threshold"
            ]
          }
        },
        {
          "id": "R06_new_vendor",
          "outcome": "LEGAL_REVIEW",
          "label": "구매검토(HITL) — 신규 벤더 실사 수기 확인(구매 담당자)",
          "basis": "신규 벤더이면 실사 수기 확인을 위해 검토",
          "when": {
            "==": [
              "$is_new_vendor",
              true
            ]
          }
        },
        {
          "id": "R07_unit_price_deviation",
          "outcome": "LEGAL_REVIEW",
          "label": "구매검토(HITL) — 단가 편차 초과(편차 사유 정당성 판단)",
          "basis": "단가 편차율이 임계를 초과하면 편차 사유 정당성 판단",
          "when": {
            ">": [
              "$unit_price_deviation_pct",
              "$unit_price_deviation_threshold"
            ]
          }
        },
        {
          "id": "R08_budget_imminent",
          "outcome": "LEGAL_REVIEW",
          "label": "구매검토(HITL) — 예산 임박 승급(보수 risk appetite)",
          "basis": "예산 사용률이 검토 임계 이상이면 보수적 risk appetite로 승급",
          "when": {
            ">=": [
              "$budget_usage_pct",
              "$budget_usage_review_threshold"
            ]
          }
        },
        {
          "id": "R09_extract_spec_review",
          "outcome": "LEGAL_REVIEW",
          "label": "구매검토(HITL) — 견적 추출·사양 일치 사람 확인",
          "basis": "견적 추출 신뢰도가 임계 미만이거나 사양 일치가 모호하면 사람 확인",
          "when": {
            "any": [
              {
                "<": [
                  "$quote_extract_confidence",
                  "$quote_confidence_threshold"
                ]
              },
              {
                "==": [
                  "$spec_match",
                  "모호"
                ]
              }
            ]
          }
        },
        {
          "id": "R10_auto_approve",
          "outcome": "AUTO_APPROVE",
          "label": "자동승인 (저위험·소액·규정 충족)",
          "basis": "모든 결정론 점검(R01~R04)과 HITL 승급 사유(R05~R09)에 해당하지 않고 발주금액이 자동승인 상한 이하이면 자동승인",
          "when": {
            "all": [
              {
                "not": {
                  "<": [
                    "$budget_after_order",
                    0
                  ]
                }
              },
              {
                "not": {
                  "any": [
                    {
                      "in": [
                        "$vendor_status",
                        [
                          "제재",
                          "거래정지"
                        ]
                      ]
                    },
                    {
                      "==": [
                        "$vendor_biz_no_valid",
                        false
                      ]
                    }
                  ]
                }
              },
              {
                "not": {
                  "all": [
                    {
                      ">=": [
                        "$order_amount",
                        5000000
                      ]
                    },
                    {
                      "!=": [
                        "$purchase_type",
                        "단가계약"
                      ]
                    },
                    {
                      "<": [
                        "$quote_count",
                        3
                      ]
                    }
                  ]
                }
              },
              {
                "not": {
                  "any": [
                    {
                      "==": [
                        "$spec_attached",
                        false
                      ]
                    },
                    {
                      "<": [
                        "$quote_valid_until",
                        "$today"
                      ]
                    }
                  ]
                }
              },
              {
                "not": {
                  ">=": [
                    "$split_score",
                    "$split_score_review_threshold"
                  ]
                }
              },
              {
                "not": {
                  "==": [
                    "$is_new_vendor",
                    true
                  ]
                }
              },
              {
                "not": {
                  ">": [
                    "$unit_price_deviation_pct",
                    "$unit_price_deviation_threshold"
                  ]
                }
              },
              {
                "not": {
                  ">=": [
                    "$budget_usage_pct",
                    "$budget_usage_review_threshold"
                  ]
                }
              },
              {
                "not": {
                  "any": [
                    {
                      "<": [
                        "$quote_extract_confidence",
                        "$quote_confidence_threshold"
                      ]
                    },
                    {
                      "==": [
                        "$spec_match",
                        "모호"
                      ]
                    }
                  ]
                }
              },
              {
                "<=": [
                  "$order_amount",
                  "$auto_approve_amount_cap"
                ]
              }
            ]
          }
        },
        {
          "id": "R11_high_amount_review",
          "outcome": "LEGAL_REVIEW",
          "label": "구매검토(HITL) — 점검은 PASS이나 고액이라 결재선 승인 필요",
          "basis": "모든 결정론 점검과 HITL 승급 사유에 해당하지 않으나 발주금액이 자동승인 상한을 초과하면 결재선 승인 필요",
          "when": {
            "all": [
              {
                "not": {
                  "<": [
                    "$budget_after_order",
                    0
                  ]
                }
              },
              {
                "not": {
                  "any": [
                    {
                      "in": [
                        "$vendor_status",
                        [
                          "제재",
                          "거래정지"
                        ]
                      ]
                    },
                    {
                      "==": [
                        "$vendor_biz_no_valid",
                        false
                      ]
                    }
                  ]
                }
              },
              {
                "not": {
                  "all": [
                    {
                      ">=": [
                        "$order_amount",
                        5000000
                      ]
                    },
                    {
                      "!=": [
                        "$purchase_type",
                        "단가계약"
                      ]
                    },
                    {
                      "<": [
                        "$quote_count",
                        3
                      ]
                    }
                  ]
                }
              },
              {
                "not": {
                  "any": [
                    {
                      "==": [
                        "$spec_attached",
                        false
                      ]
                    },
                    {
                      "<": [
                        "$quote_valid_until",
                        "$today"
                      ]
                    }
                  ]
                }
              },
              {
                "not": {
                  ">=": [
                    "$split_score",
                    "$split_score_review_threshold"
                  ]
                }
              },
              {
                "not": {
                  "==": [
                    "$is_new_vendor",
                    true
                  ]
                }
              },
              {
                "not": {
                  ">": [
                    "$unit_price_deviation_pct",
                    "$unit_price_deviation_threshold"
                  ]
                }
              },
              {
                "not": {
                  ">=": [
                    "$budget_usage_pct",
                    "$budget_usage_review_threshold"
                  ]
                }
              },
              {
                "not": {
                  "any": [
                    {
                      "<": [
                        "$quote_extract_confidence",
                        "$quote_confidence_threshold"
                      ]
                    },
                    {
                      "==": [
                        "$spec_match",
                        "모호"
                      ]
                    }
                  ]
                }
              },
              {
                ">": [
                  "$order_amount",
                  "$auto_approve_amount_cap"
                ]
              }
            ]
          }
        }
      ],
      "default": {
        "id": "R99_fallback_review",
        "outcome": "LEGAL_REVIEW",
        "label": "구매검토(HITL) — 미분류, 결재선 판단 필요",
        "basis": "위 어떤 룰에도 매칭되지 않은 케이스는 안전하게 사람 검토로 회부 (catch-all)"
      }
    }
  },
