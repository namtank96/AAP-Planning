  "knowledge": {
    "route": {
      "rules": [
        {
          "id": "R01_missing_required_evidence",
          "outcome": "REJECT",
          "label": "반려(필수증빙 누락)",
          "basis": "증빙 미첨부 또는 적격증빙 아님+증빙없음 유형",
          "when": {
            "any": [
              {
                "==": [
                  "$evidenceAttached",
                  false
                ]
              },
              {
                "all": [
                  {
                    "==": [
                      "$isQualifiedEvidence",
                      false
                    ]
                  },
                  {
                    "==": [
                      "$evidenceType",
                      "증빙없음"
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "id": "R02_prohibited_item",
          "outcome": "REJECT",
          "label": "반려(정책 위반)",
          "basis": "금지품목 플래그(주류/개인경비/금지업종)",
          "when": {
            "==": [
              "$prohibitedItemFlag",
              true
            ]
          }
        },
        {
          "id": "R03_period_deadline_over",
          "outcome": "REJECT",
          "label": "반려(청구 기간 도과)",
          "basis": "청구 기간 도과(>90일)",
          "when": {
            ">": [
              "$periodGapDays",
              90
            ]
          }
        },
        {
          "id": "R04_exact_duplicate",
          "outcome": "REJECT",
          "label": "반려(명백 중복 청구)",
          "basis": "키 완전일치 명백 중복(claimant·date·merchant·amount)",
          "when": {
            "==": [
              "$duplicateFlag",
              true
            ]
          }
        },
        {
          "id": "R05_limit_excess",
          "outcome": "LEGAL_REVIEW",
          "label": "검토(HITL: 한도 초과액 삭감/예외 판단)",
          "basis": "한도 초과액 발생",
          "when": {
            ">": [
              "$limitExcessAmount",
              0
            ]
          }
        },
        {
          "id": "R06_account_tax_review",
          "outcome": "LEGAL_REVIEW",
          "label": "검토(HITL: 계정·세무 확정)",
          "basis": "계정 불일치 또는 세무 자문 필요",
          "when": {
            "any": [
              {
                "==": [
                  "$accountMismatchFlag",
                  true
                ]
              },
              {
                "==": [
                  "$taxAdvisoryFlag",
                  true
                ]
              }
            ]
          }
        },
        {
          "id": "R07_ocr_amount_review",
          "outcome": "LEGAL_REVIEW",
          "label": "검토(HITL: 수기 확인)",
          "basis": "OCR 신뢰도 미달 또는 금액 불일치 허용오차 초과",
          "when": {
            "any": [
              {
                "<": [
                  "$ocrConfidence",
                  0.8
                ]
              },
              {
                ">": [
                  "$amountMismatch",
                  "$th_amount_tolerance"
                ]
              }
            ]
          }
        },
        {
          "id": "R08_dup_split_recon_review",
          "outcome": "LEGAL_REVIEW",
          "label": "검토(HITL: 중복/분할/대사 소명)",
          "basis": "근접 중복 또는 분할 또는 카드대사 불일치(명세없음/청구없음)",
          "when": {
            "any": [
              {
                "==": [
                  "$duplicateFlag",
                  true
                ]
              },
              {
                "==": [
                  "$splitFlag",
                  true
                ]
              },
              {
                "in": [
                  "$cardReconStatus",
                  [
                    "명세없음",
                    "청구없음"
                  ]
                ]
              }
            ]
          }
        },
        {
          "id": "R09_high_amount_high_risk_review",
          "outcome": "LEGAL_REVIEW",
          "label": "검토(HITL: 고액·고위험)",
          "basis": "위험점수 ≥60 또는 청구총액 >200만",
          "when": {
            "any": [
              {
                ">=": [
                  "$riskScore",
                  60
                ]
              },
              {
                ">": [
                  "$claimTotalAmount",
                  2000000
                ]
              }
            ]
          }
        },
        {
          "id": "R10_auto_approve_low_amount",
          "outcome": "AUTO_APPROVE",
          "label": "자동승인",
          "basis": "위 전부 미해당 AND 청구총액 ≤30만 AND 적격증빙",
          "when": {
            "all": [
              {
                "<=": [
                  "$claimTotalAmount",
                  300000
                ]
              },
              {
                "==": [
                  "$isQualifiedEvidence",
                  true
                ]
              }
            ]
          }
        },
        {
          "id": "R11_auto_approve_mid_amount",
          "outcome": "AUTO_APPROVE",
          "label": "자동승인(중액·정상)",
          "basis": "위 전부 미해당 AND 30만<청구총액≤200만 AND 적격증빙 AND 위험점수<60",
          "when": {
            "all": [
              {
                ">": [
                  "$claimTotalAmount",
                  300000
                ]
              },
              {
                "<=": [
                  "$claimTotalAmount",
                  2000000
                ]
              },
              {
                "==": [
                  "$isQualifiedEvidence",
                  true
                ]
              },
              {
                "<": [
                  "$riskScore",
                  60
                ]
              }
            ]
          }
        }
      ],
      "default": {
        "id": "FB_manual_review",
        "outcome": "LEGAL_REVIEW",
        "label": "검토(미분류: 수기 판단)",
        "basis": "어떤 룰에도 해당하지 않는 잔여 케이스는 안전하게 사람 검토로 회부"
      }
    }
  },
