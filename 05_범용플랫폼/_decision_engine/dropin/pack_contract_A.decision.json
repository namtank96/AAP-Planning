  "knowledge": {
    "route": {
      "rules": [
        {
          "id": "R1",
          "outcome": "REJECT",
          "label": "반려(치명 결격)",
          "basis": "제재 리스트 적중 또는 신용등급 E/F(거래정지 포함) — 치명 결격",
          "when": {
            "any": [
              {
                "==": [
                  "$sanctionListHit",
                  true
                ]
              },
              {
                "in": [
                  "$creditGrade",
                  [
                    "E",
                    "F"
                  ]
                ]
              }
            ]
          }
        },
        {
          "id": "R2",
          "outcome": "REJECT",
          "label": "반려(핵심 필수조항 누락)",
          "basis": "손해배상/해지/준거법/관할 등 핵심 필수조항 누락",
          "when": {
            "intersects": [
              "$missingMandatoryClauses",
              [
                "손해배상",
                "해지",
                "준거법",
                "관할"
              ]
            ]
          }
        },
        {
          "id": "R3",
          "outcome": "REJECT",
          "label": "반려(금액 정합 실패·요청자 보완)",
          "basis": "ERP 발주금액 불일치",
          "when": {
            "==": [
              "$amountMatchesPo",
              false
            ]
          }
        },
        {
          "id": "R4",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(추출 신뢰도 저하·문서 보완)",
          "basis": "PDF 추출 신뢰도 0.7 미만",
          "when": {
            "<": [
              "$pdfExtractConfidence",
              0.7
            ]
          }
        },
        {
          "id": "R5",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(템플릿 편차 자동대조 불가 갭 → HITL 보완)",
          "basis": "템플릿 미디지털화 + 신규/변경 건 → 자동대조 불가",
          "when": {
            "all": [
              {
                "==": [
                  "$templateDigitalized",
                  false
                ]
              },
              {
                "in": [
                  "$contractNature",
                  [
                    "신규",
                    "변경"
                  ]
                ]
              }
            ]
          }
        },
        {
          "id": "R6",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(독소조항 심층검토)",
          "basis": "고위험 독소조항 1건 이상 적중",
          "when": {
            ">=": [
              "$toxicHighCount",
              1
            ]
          }
        },
        {
          "id": "R7",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(보수 임계·경계대역 회부)",
          "basis": "종합 위험 점수 30 이상(보수 임계)",
          "when": {
            ">=": [
              "$compositeRiskScore",
              30
            ]
          }
        },
        {
          "id": "R8",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(평판·신용 간접 리스크)",
          "basis": "평판 리스크 의심 이상 또는 신용등급 D",
          "when": {
            "any": [
              {
                "in": [
                  "$reputationRisk",
                  [
                    "의심",
                    "높음"
                  ]
                ]
              },
              {
                "==": [
                  "$creditGrade",
                  "D"
                ]
              }
            ]
          }
        },
        {
          "id": "R8B",
          "outcome": "LEGAL_REVIEW",
          "label": "법무검토(미매칭 독소조항 보완 검토)",
          "basis": "자동대조 패턴 미매칭 독소조항 1건 이상 → 자동승인 누출 차단·HITL 회부",
          "when": {
            ">=": [
              "$toxicUnmatchedCount",
              1
            ]
          }
        },
        {
          "id": "R9",
          "outcome": "AUTO_APPROVE",
          "label": "자동승인(결재선 자동구성→상신)",
          "basis": "필수조항·독소조항(고위험·미매칭)·정합·제재·신뢰도·위험점수 모두 정상 → 자동승인",
          "when": {
            "all": [
              {
                "empty": "$missingMandatoryClauses"
              },
              {
                "==": [
                  "$toxicHighCount",
                  0
                ]
              },
              {
                "==": [
                  "$toxicUnmatchedCount",
                  0
                ]
              },
              {
                "==": [
                  "$templateDigitalized",
                  true
                ]
              },
              {
                "==": [
                  "$amountMatchesPo",
                  true
                ]
              },
              {
                "==": [
                  "$sanctionListHit",
                  false
                ]
              },
              {
                "<": [
                  "$compositeRiskScore",
                  30
                ]
              },
              {
                ">=": [
                  "$pdfExtractConfidence",
                  0.7
                ]
              }
            ]
          }
        }
      ],
      "default": {
        "id": "R_FALLBACK",
        "outcome": "LEGAL_REVIEW",
        "label": "법무검토(보수 기본값: 모호 시 HITL)",
        "basis": "어느 규칙에도 해당하지 않는 경계 건 — 보수적 HITL 회부"
      }
    }
