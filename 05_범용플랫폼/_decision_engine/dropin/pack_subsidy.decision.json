        "extract": "rule"
      },
      {
        "key": "grantDecisionType",
        "label": "교부 형태(승인/조건부/감액/반려)",
        "type": "string",
        "source": "전결권자 재량 판단",
        "extract": "manual"
      },
      {
        "key": "writebackStatus",
        "label": "교부 결정·예산 차감 writeback 결과",
        "type": "string",
        "source": "e나라도움(API read-write)",
        "extract": "connector"
      },
      {
        "key": "requiredDocsDetail"
      },
      {
        "key": "eligibilityCriteriaDetail"
      }
    ]
  },
  "knowledge": {
    "route": {
      "rules": [
        {
          "id": "R0_HITL_DELEGATION",
          "outcome": "LEGAL_REVIEW",
          "label": "HITL 검토 — 전결권 초과 심사위원회 의결",
          "basis": "교부가능액이 전결 한도(5천만원)를 초과(grantableAmount>50000000)하면 정량요건 충족 여부와 무관하게 자동승인 금지 → 심사위원회 의결 회부(th_delegation_committee). 자동승인(R1)보다 먼저 평가",
          "when": {
            "all": [
              {
                ">": [
                  "$grantableAmount",
                  50000000
                ]
              },
              {
                "!=": [
                  "$eligibilityCriteria",
                  "FAIL"
                ]
              },
              {
                "==": [
                  "$duplicateBenefitFlag",
                  false
                ]
              },
              {
                "==": [
                  "$fraudHistoryFlag",
                  false
                ]
              },
              {
                "==": [
                  "$arrearsBankruptcyFlag",
                  false
                ]
              },
              {
                "==": [
                  "$requiredDocsStatus",
                  "COMPLETE"
                ]
              },
              {
                "==": [
                  "$docValidityOk",
                  true
                ]
              }
            ]
          }
        },
        {
          "id": "R4_REJECT",
          "outcome": "REJECT",
          "label": "반려",
          "basis": "자격미달(eligibilityCriteria=FAIL) OR 중복수혜 OR 부정수급 이력 OR 연체·파산 OR 서류미비/무효가 명백 → 반려. 단 R6(연체·파산 회색대 HITL)가 먼저 걸리는 케이스는 제외하기 위해 부정수급은 fraudHistoryFlag로만 차단",
          "when": {
            "any": [
              {
                "==": [
                  "$eligibilityCriteria",
                  "FAIL"
                ]
              },
              {
                "==": [
                  "$duplicateBenefitFlag",
                  true
                ]
              },
              {
                "==": [
                  "$fraudHistoryFlag",
                  true
                ]
              },
              {
                "not": {
                  "==": [
                    "$requiredDocsStatus",
                    "COMPLETE"
                  ]
                }
              },
              {
                "==": [
                  "$docValidityOk",
                  false
                ]
              }
            ]
          }
        },
        {
          "id": "R6_HITL_ARREARS",
          "outcome": "LEGAL_REVIEW",
          "label": "HITL 검토 — 연체·파산 + 부정신호 중간대",
          "basis": "부정수급 이력 확정은 아니나 연체·파산 상태(arrearsBankruptcyFlag=true)이고 부정신호 점수가 중간대(40<=fraudSignalScore<70)면 SIU성 정밀검토 필요(th_fraud_review) → 심사위원 검토",
          "when": {
            "all": [
              {
                "==": [
                  "$fraudHistoryFlag",
                  false
                ]
              },
              {
                "==": [
                  "$arrearsBankruptcyFlag",
                  true
                ]
              },
              {
                ">=": [
                  "$fraudSignalScore",
                  40
                ]
              },
              {
                "<": [
                  "$fraudSignalScore",
                  70
                ]
              },
              {
                "==": [
                  "$duplicateBenefitFlag",
                  false
                ]
              },
              {
                "!=": [
                  "$eligibilityCriteria",
                  "FAIL"
                ]
              },
              {
                "==": [
                  "$requiredDocsStatus",
                  "COMPLETE"
                ]
              },
              {
                "==": [
                  "$docValidityOk",
                  true
                ]
              }
            ]
          }
        },
        {
          "id": "R3_HITL_GRAYZONE",
          "outcome": "LEGAL_REVIEW",
          "label": "HITL 검토 — 경계·재량 회색지대",
          "basis": "정량 충족(서류·유효·중복/부정/연체 없음)하나 형평·정책목적상 경계·재량 회색지대(eligibilityCriteria=GRAYZONE) → 심사위원 검토",
          "when": {
            "all": [
              {
                "==": [
                  "$requiredDocsStatus",
                  "COMPLETE"
                ]
              },
              {
                "==": [
                  "$docValidityOk",
                  true
                ]
              },
              {
                "==": [
                  "$duplicateBenefitFlag",
                  false
                ]
              },
              {
                "==": [
                  "$fraudHistoryFlag",
                  false
                ]
              },
              {
                "==": [
                  "$arrearsBankruptcyFlag",
                  false
                ]
              },
              {
                "==": [
                  "$eligibilityCriteria",
                  "GRAYZONE"
                ]
              }
            ]
          }
        },
        {
          "id": "R5_HITL_BUDGET",
          "outcome": "LEGAL_REVIEW",
          "label": "HITL 검토 — 예산 잔액 부족",
          "basis": "정량 충족(서류·유효·자격 PASS·중복/부정/연체 없음)하나 예산 잔액이 지급가능액 미만(budgetRemaining<grantableAmount) → 예산 초과 교부 금지, 감액/보류 재량 심사위원 검토(th_budget_block)",
          "when": {
            "all": [
              {
                "==": [
                  "$requiredDocsStatus",
                  "COMPLETE"
                ]
              },
              {
                "==": [
                  "$docValidityOk",
                  true
                ]
              },
              {
                "==": [
                  "$eligibilityCriteria",
                  "PASS"
                ]
              },
              {
                "==": [
                  "$duplicateBenefitFlag",
                  false
                ]
              },
              {
                "==": [
                  "$fraudHistoryFlag",
                  false
                ]
              },
              {
                "==": [
                  "$arrearsBankruptcyFlag",
                  false
                ]
              },
              {
                "<": [
                  "$budgetRemaining",
                  "$grantableAmount"
                ]
              }
            ]
          }
        },
        {
          "id": "R2_HITL_QUALITATIVE",
          "outcome": "LEGAL_REVIEW",
          "label": "HITL 검토 — 정성평가 필요",
          "basis": "정량요건은 충족(서류 완비·유효·자격 PASS·중복/부정/연체 없음·예산 내)이나 정성평가 준비 미완(qualitativePlanReady=false)라 심사위원 정성평가 필수",
          "when": {
            "all": [
              {
                "==": [
                  "$requiredDocsStatus",
                  "COMPLETE"
                ]
              },
              {
                "==": [
                  "$docValidityOk",
                  true
                ]
              },
              {
                "==": [
                  "$eligibilityCriteria",
                  "PASS"
                ]
              },
              {
                "==": [
                  "$duplicateBenefitFlag",
                  false
                ]
              },
              {
                "==": [
                  "$fraudHistoryFlag",
                  false
                ]
              },
              {
                "==": [
                  "$arrearsBankruptcyFlag",
                  false
                ]
              },
              {
                ">=": [
                  "$budgetRemaining",
                  "$grantableAmount"
                ]
              },
              {
                "==": [
                  "$qualitativePlanReady",
                  false
                ]
              }
            ]
          }
        },
        {
          "id": "R1_AUTO_APPROVE",
          "outcome": "AUTO_APPROVE",
          "label": "자동승인 후보",
          "basis": "전 정량요건 PASS(서류 완비·서류 유효·정량 자격요건 충족) AND 중복·부정·연체/파산 없음 AND 예산 내(예산 잔액≥지급가능액) AND 정성평가 불요(qualitativePlanReady=true) AND 교부가능액 전결 한도 내(grantableAmount<=50000000)",
          "when": {
            "all": [
              {
                "==": [
                  "$requiredDocsStatus",
                  "COMPLETE"
                ]
              },
              {
                "==": [
                  "$docValidityOk",
                  true
                ]
              },
              {
                "==": [
                  "$eligibilityCriteria",
                  "PASS"
                ]
              },
              {
                "==": [
                  "$duplicateBenefitFlag",
                  false
                ]
              },
              {
                "==": [
                  "$fraudHistoryFlag",
                  false
                ]
              },
              {
                "==": [
                  "$arrearsBankruptcyFlag",
                  false
                ]
              },
              {
                ">=": [
                  "$budgetRemaining",
                  "$grantableAmount"
                ]
              },
              {
                "==": [
                  "$qualitativePlanReady",
                  true
                ]
              },
              {
                "<=": [
                  "$grantableAmount",
                  50000000
                ]
              }
            ]
          }
        }
      ],
      "default": {
        "id": "FB_HITL",
        "outcome": "LEGAL_REVIEW",
        "label": "HITL 검토 — 미분류 케이스",
        "basis": "명시 룰에 해당하지 않는 잔여 케이스는 자동 처리하지 않고 심사위원 검토로 회부(안전한 기본값)"
      }
    }
  },
