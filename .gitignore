# Claude Code 로컬 설정 (개인 설정은 제외, 공유 에이전트 정의는 추적)
.claude/*
!.claude/agents/
.claude/settings.local.json

# OS 메타 파일
.DS_Store
Thumbs.db
desktop.ini

# MS Office 임시 파일
~$*.docx
~$*.xlsx
~$*.pptx
~$*.html

# 에디터 임시·백업
*.bak
*.tmp
*~
.vscode/
.idea/

# 로그
*.log

# 프로토타입 의존성·빌드 산출물
node_modules/
.venv/
.next/
__pycache__/
*.pyc

# 로컬 DB / 시크릿 (예제 파일 .env.example, .env.local.example 은 추적 유지)
*.db
.env
.env.local
